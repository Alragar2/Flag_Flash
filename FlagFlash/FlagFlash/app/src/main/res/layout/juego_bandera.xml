<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background">

    <ImageView
        android:id="@+id/myImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/points"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/puntuacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/myImage"
        app:layout_constraintStart_toEndOf="@+id/myImage"
        app:layout_constraintTop_toTopOf="@id/myImage"
        android:layout_marginStart="8dp" />

    <!-- Mascota Activa -->
    <ImageView
        android:id="@+id/ivPetActive"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/corazon3"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/corazon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp" />

    <ImageView
        android:id="@+id/corazon2"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/corazon"
        app:layout_constraintEnd_toStartOf="@+id/corazon3"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp" />

    <ImageView
        android:id="@+id/corazon1"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/corazon"
        app:layout_constraintEnd_toStartOf="@+id/corazon2"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:id="@+id/linearLayoutProgressBars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/myImage"
        android:layout_marginTop="20dp">
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:min="0"
            android:max="10"
            android:minHeight="50dp"
            android:progress="0"
            android:indeterminate="false"
            android:layout_marginRight="16dp"
            android:progressTint="#6200EE"
            android:progressBackgroundTint="#3700B3"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/10" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Qué país es?"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/linearLayoutProgressBars"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <ImageView
        android:id="@+id/bandera"
        android:layout_width="270dp"
        android:layout_height="180dp"
        android:src="@drawable/bandera_de_espana"
        app:layout_constraintTop_toBottomOf="@id/tvQuestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/Pais1"
        android:layout_width="0dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#2E8DFF"
        android:text="Opcion 1"
        app:layout_constraintTop_toBottomOf="@id/bandera"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/Pais2"
        android:layout_width="0dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#2E8DFF"
        android:text="Opcion 2"
        app:layout_constraintTop_toBottomOf="@id/Pais1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/Pais3"
        android:layout_width="0dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#2E8DFF"
        android:text="Opcion 3"
        app:layout_constraintTop_toBottomOf="@id/Pais2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/Pais4"
        android:layout_width="0dp"
        android:layout_marginStart="60dp"
        android:layout_marginEnd="60dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#2E8DFF"
        android:text="Opcion 4"
        app:layout_constraintTop_toBottomOf="@id/Pais3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Botón de Habilidad Búho -->
    <ImageButton
        android:id="@+id/btnOwlAbility"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/buho"
        android:scaleType="centerInside"
        android:background="@drawable/rounded_corners"
        android:backgroundTint="#FFEB3B"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>