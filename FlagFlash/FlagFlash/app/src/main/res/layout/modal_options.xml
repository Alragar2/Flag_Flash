<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="15dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/modalNombreUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre"
        android:textColor="@android:color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/statsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/modalNombreUsuario">

        <ImageView
            android:id="@+id/puntos_view"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/points" />

        <TextView
            android:id="@+id/modalPuntuacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="18sp"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/moneda_view"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/moneda" />

        <TextView
            android:id="@+id/modalMonedas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#E9AC12"
            android:textSize="16sp"
            />


    </LinearLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/statsContainer" />

    <!-- Sección de Alimento -->
    <LinearLayout
        android:id="@+id/foodSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider1">

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/alimento" />

        <TextView
            android:id="@+id/modalFoodCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="x0"
            android:layout_marginStart="4dp"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <Button
            android:id="@+id/modalBtnFeed"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Alimentar"
            android:textSize="12sp"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/foodSection" />

    <!-- Mascotas Poseídas -->
    <TextView
        android:id="@+id/modalOwnedPetsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tus Mascotas"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/modalPetsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/modalOwnedPetsTitle">
        
        <!-- Búho -->
        <FrameLayout
            android:id="@+id/containerBuho"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/petIconBuho"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/buho"
                android:padding="4dp" />
            <ImageView
                android:id="@+id/petFedIndicatorBuho"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/tick_verde"
                android:layout_gravity="top|end"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Gato -->
        <FrameLayout
            android:id="@+id/containerGato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/petIconGato"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/gatito"
                android:padding="4dp" />
            <ImageView
                android:id="@+id/petFedIndicatorGato"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/tick_verde"
                android:layout_gravity="top|end"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Tortuga -->
        <FrameLayout
            android:id="@+id/containerTortuga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/petIconTortuga"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/tortuguita"
                android:padding="4dp" />
            <ImageView
                android:id="@+id/petFedIndicatorTortuga"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/tick_verde"
                android:layout_gravity="top|end"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/modalPetStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ninguna seleccionada"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="italic"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/modalPetsContainer" />

    <Button
        android:id="@+id/modalCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar Sesión"
        android:backgroundTint="#FF2E2E"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/modalPetStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/modalEliminarCuenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Eliminar Cuenta"
        android:backgroundTint="#990000"
        app:layout_constraintTop_toBottomOf="@+id/modalCerrarSesion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>