<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlagFlash"
        tools:targetApi="31">

        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-6281701644214410~5770125711"/>

        <activity
            android:name=".resultado.ElegirJugarActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>
        <activity
            android:name=".resultado.ElegirMultijugarActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.JuegoBanderaActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.JuegoPaisActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.MultijugadorBanderaActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.MultijugadorPaisActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".resultado.VictoriaMJActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".resultado.VictoriaMJActivity2"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".galeria.GaleriaActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".resultado.PaisAdapter"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".resultado.VictoriaIndividualActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".resultado.DerrotaIndividualActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".UserPreferences"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.JuegoCapitalActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.JuegoEscudoActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".juego.MultijugadorCapitalActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".ranking.RankingActivity"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <activity android:name=".authentication.AuthenticationRegisterActivity"
            android:screenOrientation="portrait"></activity>

        <activity android:name=".authentication.AuthenticationLoginActivity"
            android:screenOrientation="portrait"></activity>


        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".musica.MusicService"
            android:enabled="true"
            android:exported="true"
            android:stopWithTask="false">
        </service>

    </application>
    <uses-permission android:name="android.permission.VIBRATE"/>
</manifest>